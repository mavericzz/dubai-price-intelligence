# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service-role key — keep this secret, never commit it
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Rotating residential proxy endpoint (e.g. http://user:pass@proxy.provider.com:port)
# Leave empty to scrape without a proxy (not recommended for production)
ROTATING_PROXY_URL=http://username:password@proxy.example.com:10000

# Webhook URL to POST a JSON alert when scraped < 50 listings
# e.g. a Slack incoming webhook or a custom health endpoint
HEALTH_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
