# Supabase — anon key for public/client reads
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Supabase — service role key for backend jobs (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Twilio WhatsApp
# Get these from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=<auth-token>
# Sandbox sender: whatsapp:+14155238886
# Production: your approved WhatsApp Business number with whatsapp: prefix
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Deep links in WhatsApp messages
APP_BASE_URL=https://dubaipriceint.com
